---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../data/site';

const targetHref = withBase('/research');
const summariesHref = withBase('/summaries');
---

<BaseLayout
  title="Summaries Redirect | Robert Jenkinson Alvarez"
  description="Summaries have moved."
  noindex
>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0;url=${targetHref}`} />
    <link rel="canonical" href={targetHref} />
  </Fragment>

  <section class="surface-light section-space section-divider">
    <div class="page-shell max-w-3xl space-y-5 text-center">
      <h1 class="section-title">Summaries have moved.</h1>
      <p>
        <a href={targetHref} class="site-nav-cta">Go to research</a>
      </p>
    </div>
  </section>

  <script is:inline define:vars={{ targetHref, summariesHref }}>
    if (window.location.pathname === summariesHref || window.location.pathname === `${summariesHref}/`) {
      window.location.replace(targetHref);
    }
  </script>
</BaseLayout>
