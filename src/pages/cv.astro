---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../data/site';

const aboutHref = withBase('/about');
const cvHref = withBase('/cv');
---

<BaseLayout title="CV Redirect | Robert Jenkinson Alvarez" description="Moved to About / CV." noindex>
  <section class="section-space surface-light section-divider">
    <div class="page-shell max-w-3xl space-y-5 text-center" data-reveal>
      <h1 class="section-title">Redirecting to About / CV</h1>
      <p class="lede mx-auto">CVs are on the About / CV page.</p>
      <p>
        <a href={aboutHref} class="site-nav-cta">Continue to About / CV</a>
      </p>
    </div>
  </section>

  <script is:inline define:vars={{ aboutHref, cvHref }}>
    if (window.location.pathname === cvHref || window.location.pathname === `${cvHref}/`) {
      window.location.replace(aboutHref);
    }
  </script>
</BaseLayout>
