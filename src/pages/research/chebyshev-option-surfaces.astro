---
import { existsSync, readdirSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Badge from '../../components/Badge.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChebyshevVisualGuideBody from '../../content/chebyshev-visual-guide-body.mdx';
import katex from 'katex';
import { isPlaceholderLink, siteConfig, toAbsoluteUrl, withBase } from '../../data/site';

type MediaAsset = {
  name: string;
  lower: string;
  src: string;
};

const imagesDir = fileURLToPath(new URL('../../../public/images/chebyshev', import.meta.url));
const mediaExtensions = new Set(['.png', '.jpg', '.jpeg', '.webp', '.svg', '.pdf', '.gif', '.mp4', '.webm']);

const mediaAssets: MediaAsset[] = existsSync(imagesDir)
  ? readdirSync(imagesDir)
      .filter((name) => {
        const dotIndex = name.lastIndexOf('.');
        return dotIndex > 0 && mediaExtensions.has(name.slice(dotIndex).toLowerCase());
      })
      .map((name) => ({
        name,
        lower: name.toLowerCase(),
        src: withBase(`/images/chebyshev/${name}`)
      }))
  : [];

function findExactAsset(name: string): string | undefined {
  return mediaAssets.find((asset) => asset.lower === name.toLowerCase())?.src;
}

function resolveStaticFigure(stem: string): string | undefined {
  const preferredExtensions = ['.png', '.jpg', '.jpeg', '.webp', '.svg', '.pdf'];

  for (const extension of preferredExtensions) {
    const asset = findExactAsset(`${stem}${extension}`);
    if (asset) {
      return asset;
    }
  }

  return undefined;
}

function resolveOrbitFigure(stem: string): string | undefined {
  const preferredExtensions = ['.mp4', '.gif', '.png', '.jpg', '.jpeg', '.webp', '.svg', '.pdf'];

  for (const extension of preferredExtensions) {
    const asset = findExactAsset(`${stem}${extension}`);
    if (asset) {
      return asset;
    }
  }

  return undefined;
}

const assets = {
  forwardOrbit: resolveOrbitFigure('00_hero_price_sheet_orbit'),
  forwardSheet: resolveStaticFigure('00_hero_price_sheet'),
  quoteDensity: resolveStaticFigure('01_quote_density_raw'),
  warpMAsinh: resolveStaticFigure('02_warp_m_asinh'),
  warpTauSqrt: resolveStaticFigure('03_warp_tau_sqrt'),
  chebyshevModes: resolveStaticFigure('04_chebyshev_modes'),
  operatorFamily: resolveStaticFigure('05_operator_family_combo'),
  staticNoArbSlices: resolveStaticFigure('06_static_noarb_slices'),
  bidAskCoverage: resolveStaticFigure('07_bid_ask_coverage'),
  hingeController: resolveStaticFigure('08_hinge_mu_controller'),
  spectralRidge: resolveStaticFigure('09_spectral_ridge'),
  lambdaWhitening: resolveStaticFigure('10_lambda_whitening'),
  dwHminus1: resolveStaticFigure('11_dw_hminus1'),
  rnShortEnd: resolveStaticFigure('12_rn_short_end'),
  omegaTaper: resolveStaticFigure('13_omega_taper'),
  metricProjection: resolveStaticFigure('14_metric_projection'),
  badnessMap: resolveStaticFigure('15_badness_map'),
  fogOrbit: resolveOrbitFigure('16_fog_lattice_orbit'),
  noiseAwarePenalty: resolveStaticFigure('17_noise_aware_penalty'),
  patchLocality: resolveStaticFigure('18_patch_locality'),
  priceVsIv: resolveStaticFigure('19_price_space_vs_iv_space')
};

const missingAssets: string[] = [];

if (!assets.forwardOrbit && !assets.forwardSheet) {
  missingAssets.push('00_hero_price_sheet_orbit.(mp4/gif/png/jpg/webp/svg/pdf) and/or 00_hero_price_sheet.(png/jpg/webp/svg/pdf)');
}

const requiredAssetPairs: Array<[string, string | undefined]> = [
  ['01_quote_density_raw', assets.quoteDensity],
  ['02_warp_m_asinh', assets.warpMAsinh],
  ['03_warp_tau_sqrt', assets.warpTauSqrt],
  ['04_chebyshev_modes', assets.chebyshevModes],
  ['05_operator_family_combo', assets.operatorFamily],
  ['06_static_noarb_slices', assets.staticNoArbSlices],
  ['07_bid_ask_coverage', assets.bidAskCoverage],
  ['08_hinge_mu_controller', assets.hingeController],
  ['09_spectral_ridge', assets.spectralRidge],
  ['10_lambda_whitening', assets.lambdaWhitening],
  ['11_dw_hminus1', assets.dwHminus1],
  ['12_rn_short_end', assets.rnShortEnd],
  ['13_omega_taper', assets.omegaTaper],
  ['14_metric_projection', assets.metricProjection],
  ['15_badness_map', assets.badnessMap],
  ['16_fog_lattice_orbit.(mp4/gif/png/jpg/webp/svg/pdf)', assets.fogOrbit],
  ['17_noise_aware_penalty', assets.noiseAwarePenalty],
  ['18_patch_locality', assets.patchLocality],
  ['19_price_space_vs_iv_space', assets.priceVsIv]
];

for (const [label, src] of requiredAssetPairs) {
  if (!src) {
    missingAssets.push(label);
  }
}

if (missingAssets.length > 0) {
  throw new Error(
    `Missing required Chebyshev visual-guide assets in public/images/chebyshev:\n- ${missingAssets.join('\n- ')}`
  );
}

const technicalSummaryHref = withBase('/research/chebyshev-option-surfaces/summary');
const paperHref = withBase('/files/Arbitrage_Free_Option_Price_Surfaces.pdf');

const preferredPdfPath = fileURLToPath(
  new URL('../../../public/files/summaries/chebyshev-technical-summary.pdf', import.meta.url)
);
const fallbackPdfPath = fileURLToPath(new URL('../../../public/files/Summary_chebyshev.pdf', import.meta.url));

const openPdfHref = existsSync(preferredPdfPath)
  ? withBase('/files/summaries/chebyshev-technical-summary.pdf')
  : existsSync(fallbackPdfPath)
    ? withBase('/files/Summary_chebyshev.pdf')
    : undefined;

const arxivHref = !isPlaceholderLink(siteConfig.links.chebyshevPaper)
  ? siteConfig.links.chebyshevPaper
  : undefined;



function renderDisplayMath(tex: string): string {
  return katex.renderToString(tex, {
    displayMode: true,
    throwOnError: false,
    strict: 'ignore'
  });
}

function isVideoAsset(src?: string): boolean {
  return Boolean(src && (src.endsWith('.mp4') || src.endsWith('.webm')));
}

const routePath = '/research/chebyshev-option-surfaces';
const canonicalUrl = toAbsoluteUrl(routePath);

const pageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: 'Arbitrage-Free Option Price Surfaces via Chebyshev Tensor Bases and a Hamiltonian Fog Post-Fit',
  alternativeHeadline: 'Visual guide',
  description:
    'Visual overview of the forward-discounted call sheet, operator-based static no-arbitrage, and local Hamiltonian fog refinement.',
  url: canonicalUrl,
  author: {
    '@type': 'Person',
    name: siteConfig.name
  },
  isAccessibleForFree: true
};
---

<BaseLayout
  title="Arbitrage-Free Option Price Surfaces via Chebyshev Tensor Bases and a Hamiltonian Fog Post-Fit | Visual guide"
  description="Visual overview of forward-discounted call-sheet geometry, no-arbitrage operators, and Hamiltonian fog refinement."
  ogType="article"
  jsonLd={pageJsonLd}
>
  <section class="section-tight ham-appendix-band">
    <div class="page-shell">
      <header class="ham-appendix-shell ham-appendix-header" data-reveal>
        <a href={withBase('/research')} class="subtle-link text-sm">
          <span aria-hidden="true">←</span> Back to research index
        </a>

        <div class="flex flex-wrap gap-2">
          <Badge label="Quantitative Finance" />
          <Badge label="Visual guide" tone="accent" />
        </div>

        <h1 class="ham-appendix-title">
          Arbitrage-Free Option Price Surfaces via Chebyshev Tensor Bases and a Hamiltonian Fog Post-Fit
        </h1>
        <p class="body-copy ham-appendix-intro">
          A visual overview of the paper’s construction of forward-discounted call sheet.
        </p>

        <nav class="ham-appendix-actions" aria-label="Chebyshev visual guide links">
          <a href={technicalSummaryHref} class="ham-action-link">
            Technical summary
          </a>
          {
            paperHref ? (
              <a
                href={paperHref}
                class="ham-action-link"
                target="_blank"
                rel="noreferrer noopener"
                aria-label="Paper PDF"
                title="Paper PDF"
              >
                Paper PDF
              </a>
            ) : (
              <span class="ham-action-link ham-action-disabled" aria-disabled="true">
                Paper PDF
              </span>
            )
          }
          {
            openPdfHref ? (
              <a
                href={openPdfHref}
                class="ham-action-link"
                target="_blank"
                rel="noreferrer noopener"
                aria-label="Summary PDF"
                title="Summary PDF"
              >
                Summary PDF
              </a>
            ) : (
              <span class="ham-action-link ham-action-disabled" aria-disabled="true">
                Summary PDF
              </span>
            )
          }
          {
            arxivHref ? (
              <a
                href={arxivHref}
                class="ham-action-link"
                target="_blank"
                rel="noreferrer noopener"
                aria-label="arXiv"
                title="arXiv"
              >
                arXiv
              </a>
            ) : (
              <span class="ham-action-link ham-action-disabled" aria-disabled="true">
                arXiv
              </span>
            )
          }
        </nav>
      </header>
    </div>
  </section>

  <section class="section-tight section-divider ham-appendix-band">
    <div class="page-shell">
      <article class="ham-appendix-shell ham-appendix-content">
        <ChebyshevVisualGuideBody />
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .ham-appendix-band {
    padding-block: clamp(2rem, 4.2vw, 3.35rem);
  }

  .ham-appendix-shell {
    margin-inline: auto;
    max-width: min(900px, 100%);
  }

  .ham-appendix-header {
    display: grid;
    gap: 0.72rem;
  }

  .ham-appendix-title {
    margin: 0;
    font-size: clamp(1.78rem, 3.45vw, 2.58rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    text-wrap: balance;
    max-width: 24ch;
  }

  .ham-appendix-intro {
    max-width: 76ch;
  }

  .ham-appendix-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.42rem;
  }

  .ham-action-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.6rem;
    border: 1px solid color-mix(in oklab, var(--line-strong) 45%, transparent);
    background: color-mix(in oklab, var(--bg-elevated) 93%, white 7%);
    padding: 0.32rem 0.64rem;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-transform: none;
    color: var(--fg);
    transition: border-color 180ms ease;
  }

  .ham-action-link:hover {
    border-color: color-mix(in oklab, var(--fg) 42%, transparent);
  }

  .ham-action-disabled {
    opacity: 0.62;
    pointer-events: none;
  }

  .ham-appendix-content {
    display: grid;
    gap: 0.35rem;
  }

  .ham-appendix-content :global(h1) {
    margin: 0;
    font-size: clamp(1.12rem, 2.2vw, 1.45rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .ham-appendix-content :global(h2) {
    margin: 0;
    font-size: clamp(1.02rem, 2vw, 1.25rem);
    font-weight: 700;
    font-family: 'Space Grotesk', 'Avenir Next', 'Helvetica Neue', sans-serif;
    line-height: 1.35;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .ham-appendix-content :global(h1 + p),
  .ham-appendix-content :global(h2 + p) {
    margin-top: 0.4rem;
  }

  .ham-appendix-content :global(h1 + .ham-geo-figure),
  .ham-appendix-content :global(h2 + .ham-geo-figure) {
    margin-top: 0.58rem;
  }

  .ham-appendix-content :global(p) {
    margin: 0;
  }

  .ham-appendix-content :global(p + p) {
    margin-top: 0.72rem;
  }

  .ham-appendix-content :global(p + ul),
  .ham-appendix-content :global(p + ol),
  .ham-appendix-content :global(ul + p),
  .ham-appendix-content :global(ol + p) {
    margin-top: 0.62rem;
  }

  .ham-appendix-content :global(ul),
  .ham-appendix-content :global(ol) {
    margin: 0;
    padding-left: 1.15rem;
    display: grid;
    gap: 0.26rem;
  }

  .ham-appendix-content :global(hr) {
    margin: 1.02rem 0 1.02rem;
    border: 0;
    border-top: 1px solid color-mix(in oklab, var(--line) 68%, transparent);
  }

  .ham-appendix-content :global(.ham-geo-figure + p) {
    margin-top: 0.62rem;
  }

  .ham-overview-box {
    border: 1px solid color-mix(in oklab, var(--line-strong) 46%, transparent);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--bg-elevated) 90%, white 10%);
    padding: clamp(0.9rem, 2vw, 1.2rem);
    display: grid;
    gap: 0.58rem;
  }

  .ham-equation-list {
    margin: 0;
    padding-left: 1rem;
    display: grid;
    gap: 0.2rem;
  }

  .ham-equation-list li {
    margin: 0;
    color: color-mix(in oklab, var(--fg) 88%, var(--muted) 12%);
  }


  .ham-katex-block {
    margin: 0.05rem 0;
    padding: 0.18rem 0;
    overflow-x: auto;
  }

  .ham-prose-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.18rem;
    color: color-mix(in oklab, var(--fg) 92%, var(--muted) 8%);
  }

  .ham-prose-list-numbered {
    list-style: decimal;
  }

  .ham-subsection {
    display: grid;
    gap: 0.62rem;
    margin-top: 0.2rem;
  }

  .ham-subsection + .ham-subsection {
    margin-top: 0.52rem;
    padding-top: 0.72rem;
    border-top: 1px solid color-mix(in oklab, var(--line) 65%, transparent);
  }

  .ham-appendix-content :global(.ham-geo-figure) {
    border: 1px solid color-mix(in oklab, var(--line-strong) 48%, transparent);
    border-radius: 1.06rem;
    background: color-mix(in oklab, var(--bg-elevated) 90%, white 10%);
    overflow: hidden;
    margin: 0;
    display: grid;
    gap: 0;
  }

  .ham-appendix-content :global(.ham-geo-figure-title) {
    margin: 0;
    padding: 0.58rem 0.8rem 0.56rem;
    font-size: 0.9rem;
    font-family: 'Space Grotesk', 'Avenir Next', 'Helvetica Neue', sans-serif;
    line-height: 1.3;
    border-bottom: 1px solid color-mix(in oklab, var(--line) 70%, transparent);
    background: color-mix(in oklab, var(--bg-elevated) 94%, white 6%);
    color: color-mix(in oklab, var(--fg) 90%, var(--muted));
  }

  .ham-appendix-content :global(.ham-geo-media-shell) {
    display: block;
    padding: 0;
    background: transparent;
  }

  .ham-appendix-content :global(.ham-geo-media) {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    background: transparent;
  }

  .ham-appendix-content :global(.ham-geo-figure-copy) {
    margin: 0;
    padding: 0.68rem 0.8rem 0.78rem;
    font-size: 0.83rem;
    line-height: 1.54;
    color: var(--muted);
    border-top: 1px solid color-mix(in oklab, var(--line) 68%, transparent);
    background: color-mix(in oklab, var(--bg-elevated) 94%, white 6%);
  }

  .ham-math-inline {
    font-family: 'Newsreader', 'Iowan Old Style', serif;
    font-weight: 600;
    letter-spacing: 0;
  }

  .ham-math-block {
    margin: 0;
    font-family: 'Newsreader', 'Iowan Old Style', serif;
    font-weight: 600;
    font-size: clamp(0.96rem, 1.7vw, 1.06rem);
    line-height: 1.45;
    color: color-mix(in oklab, var(--fg) 92%, var(--muted) 8%);
    overflow-wrap: anywhere;
  }

  .ham-appendix-shell :global(.lift) {
    transition: border-color 180ms ease;
  }

  .ham-appendix-shell :global(.lift::after) {
    display: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .ham-appendix-shell :global(.lift:hover) {
      transform: none;
      border-color: color-mix(in oklab, var(--line-strong) 55%, transparent);
      box-shadow: none;
    }
  }

  @media (max-width: 760px) {
    .ham-action-link {
      width: 100%;
    }
  }
</style>
