---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OngoingPreviewCard from '../../components/OngoingPreviewCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { ongoingWorkItems } from '../../data/ongoingWork';
import { entrySlug, projectHref, sortByOrder, summaryHref } from '../../utils/content';

const projects = (await getCollection('projects')).sort(sortByOrder);
const coreProjects = projects.filter((project) => project.data.status !== 'Ongoing');
const summaries = (await getCollection('summaries')).sort(sortByOrder);

const summaryByProjectSlug = new Map(
  summaries.map((summary) => [summary.data.projectSlug, summaryHref(summary)])
);

const calloutsBySlug: Record<string, string[]> = {
  hamjepa: ['ImageNet-100 q linear probe: 31.92 vs 24.40', 'q kNN: 24.92 vs 20.10 at 45 epochs'],
  'chebyshev-option-surfaces': ['98-99% inside-spread coverage', '<1% static no-arb violations']
};

const hamjepaCardThesis =
  'Joint Embedding Predictive Architectures (JEPAs) usually push embeddings toward an Isotropic Gaussian. We show this is the wrong target when the task geometry is structured, and replace it with a symplectic predictor on phase space.';

const projectCardThesisBySlug: Record<string, string> = {
  hamjepa: hamjepaCardThesis
};

const categories = ['All', 'Geometric ML', 'Quantitative Finance', 'Ongoing Work'];
---

<BaseLayout
  title="Research Library | Robert Jenkinson Alvarez"
  description="HamJEPA, arbitrage-free option surfaces, Hamiltonian finance, and billiard rigidity."
>
  <section id="ongoing-work" class="surface-light section-space section-divider research-index-section">
    <div class="page-shell space-y-8" data-reveal>
      <div class="section-header">
        <h2 class="section-title">Research index</h2>
      </div>

      <div class="flex flex-wrap gap-2" role="toolbar" aria-label="Project category filters">
        {categories.map((category, index) => (
          <button
            type="button"
            class:list={[
              'rounded-full border px-4 py-2 text-sm font-semibold transition-colors',
              index === 0
                ? 'border-black/35 bg-white/90 text-[color:var(--fg)]'
                : 'border-black/20 bg-white/55 text-[color:var(--muted)] hover:border-black/45 hover:text-[color:var(--fg)]'
            ]}
            data-filter-button
            data-filter-value={category}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            {category}
          </button>
        ))}
      </div>

      <div class="grid gap-6 lg:grid-cols-2" data-filter-grid>
        {
          coreProjects.map((project) => {
            const slug = entrySlug(project.id);

            return (
              <div data-project-card data-category={project.data.category}>
                <ProjectCard
                  projectHref={projectHref(project)}
                  summaryHref={summaryByProjectSlug.get(slug)}
                  title={project.data.title}
                  category={project.data.category}
                  status={project.data.status}
                  thesis={projectCardThesisBySlug[slug] ?? project.data.thesis}
                  callouts={calloutsBySlug[slug] ?? project.data.headlineMetrics}
                />
              </div>
            );
          })
        }
        {
          ongoingWorkItems.map((item) => (
            <div data-project-card data-category="Ongoing Work">
              <OngoingPreviewCard
                title={item.title}
                category={item.category}
                status={item.status}
                description={item.description}
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .research-index-section {
    padding-top: clamp(2.2rem, 4.2vw, 3.25rem);
  }
</style>

<script is:inline>
  const filterButtons = Array.from(document.querySelectorAll('[data-filter-button]'));
  const cards = Array.from(document.querySelectorAll('[data-project-card]'));

  const activeClasses = ['border-black/35', 'bg-white/90', 'text-[color:var(--fg)]'];
  const inactiveClasses = ['border-black/20', 'bg-white/55', 'text-[color:var(--muted)]'];

  function applyFilter(value) {
    cards.forEach((card) => {
      const category = card.getAttribute('data-category');
      const shouldShow = value === 'All' || category === value;
      card.toggleAttribute('hidden', !shouldShow);
    });

    filterButtons.forEach((button) => {
      const isActive = button.getAttribute('data-filter-value') === value;
      button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      activeClasses.forEach((name) => button.classList.toggle(name, isActive));
      inactiveClasses.forEach((name) => button.classList.toggle(name, !isActive));
    });
  }

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const value = button.getAttribute('data-filter-value') || 'All';
      applyFilter(value);
    });
  });
</script>
