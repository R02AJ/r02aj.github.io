---
import { existsSync, readdirSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Badge from '../../components/Badge.astro';
import ExternalLinkPills from '../../components/ExternalLinkPills.astro';
import FigureGrid from '../../components/FigureGrid.astro';
import MetricStrip from '../../components/MetricStrip.astro';
import StickyFigureStory from '../../components/StickyFigureStory.astro';
import CalloutStat from '../../components/CalloutStat.astro';
import ResearchPageShell from '../../components/research/ResearchPageShell.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isPlaceholderLink, siteConfig, toAbsoluteUrl, withBase } from '../../data/site';
import {
  entrySlug,
  readableAssetLabel,
  sortByOrder,
  summaryHref
} from '../../utils/content';

interface Props {
  project: CollectionEntry<'projects'>;
}

type LinkBadge = {
  label: 'Paper' | 'Code' | 'Zenodo' | 'GitHub' | 'arXiv Author' | 'Technical summary';
  href?: string;
};

const PROJECT_DETAILS: Record<
  string,
  {
    heroSupport: string;
    tldr: string;
    problemDeep: string;
    coreIdeaDeep: string;
    methodBullets: string[];
    resultsDeep: string;
    highlightResult: { title: string; body: string };
    figureLead: string;
    nextSteps: string[];
  }
> = {
  hamjepa: {
    heroSupport:
      'A phase-space alternative to isotropic latent priors in JEPA-style representation learning.',
    tldr:
      'HamJEPA argues that Euclidean isotropy is not a neutral latent prior once task geometry becomes structured. The framework moves representation prediction into phase space and preserves geometry through a symplectic predictor.',
    problemDeep:
      'The price of isotropy is geometric mismatch: isotropic anti-collapse pressure can stabilize directions that are mathematically convenient but task-irrelevant. In structured settings, that mismatch can reduce representational efficiency and interpretability.',
    coreIdeaDeep:
      'Each view is encoded as a phase-space state s = (q, p). This makes latent dynamics explicit and supports predictor behavior that tracks conserved structure rather than treating representation evolution as unconstrained Euclidean regression.',
    methodBullets: [
      'Use an H-energy budget so the canonical structured law follows H^{-1} rather than identity isotropy.',
      'Predict in phase space with a leapfrog / velocity-Verlet style symplectic map.',
      'Keep anti-collapse constraints without forcing isotropic Gaussian geometry in latent coordinates.',
      'Monitor symplecticity defect, reversibility, and drift as first-class diagnostics.'
    ],
    resultsDeep:
      'Compared with SIGReg baselines at matched budgets, HamJEPA improves q-side linear-probe and kNN metrics while preserving structure-aware diagnostics. The gains are visible on ImageNet-100 and increase further on CIFAR-100 at longer schedules.',
    highlightResult: {
      title: 'Highlighted result',
      body: 'At 45 epochs on ImageNet-100, q linear probe improves from 24.40 (SIGReg) to 31.92 (HamJEPA), a +7.52 delta under matched training horizon.'
    },
    figureLead:
      'The visual panel prioritizes q/p decomposition, epoch dynamics, and structural diagnostics for symplecticity, reversibility, and energy behavior.',
    nextSteps: [
      'Finalize paper and code release links for reproducibility workflows.',
      'Expand ablations on how isotropy penalties trade off against phase-space constraints.',
      'Stress-test long-horizon drift under larger-scale training regimes.'
    ]
  },
  'chebyshev-option-surfaces': {
    heroSupport:
      'A price-space first calibration pipeline with explicit no-arbitrage structure and local post-fit repair.',
    tldr:
      'The core principle is to fit the arbitrage-carrying object directly in price space, enforce static no-arbitrage via sparse linear inequalities, and reserve Hamiltonian fog for local cleanup only.',
    problemDeep:
      'Option quote surfaces can be sparse, noisy, and internally inconsistent. If no-arbitrage structure is not encoded at the right stage, calibration can look smooth but fail static checks under stress.',
    coreIdeaDeep:
      'Model forward-discounted call prices C_f(m, tau) directly. Apply endpoint-preserving warps so approximation quality improves near domain boundaries, then use a tensor Chebyshev basis on the normalized rectangle.',
    methodBullets: [
      'Represent the global surface with tensor Chebyshev basis functions over warped coordinates.',
      'Encode monotonicity, convexity, calendar monotonicity, and bounds as sparse linear inequalities.',
      'Solve a convex quadratic program as the primary global backbone.',
      'Apply Hamiltonian fog only in local post-fit patches where quote inconsistency remains.'
    ],
    resultsDeep:
      'In calm regimes, the method achieves high inside-spread coverage while keeping static no-arbitrage violations low. The emphasis is structural robustness and auditability, not black-box overfitting to noisy quotes.',
    highlightResult: {
      title: 'Highlighted result',
      body: 'Calm-regime calibration reaches 98-99% inside-spread coverage with below 1% static no-arbitrage violations.'
    },
    figureLead:
      'Visual sections focus on surface projections, constraint geometry, and post-fit fog patches where local repair is activated.',
    nextSteps: [
      'Broaden regime-conditioned diagnostics across stressed days and sparse strikes.',
      'Benchmark solver/constraint tradeoffs at larger universes and finer collocation grids.',
      'Publish additional figure packs for production monitoring workflows.'
    ]
  }
};

const RESULT_METRICS: Record<string, string[]> = {
  hamjepa: [
    '+7.52 delta at epoch 45 over SIGReg (q linear probe)',
    'ImageNet-100 q linear probe: 31.92 vs 24.40',
    'ImageNet-100 q kNN: 24.92 vs 20.10'
  ],
  'chebyshev-option-surfaces': [
    '98-99% inside-spread coverage in calm regimes',
    '<1% static no-arbitrage violations'
  ]
};

const SECTION_LINKS = [
  { id: 'tldr', label: 'TL;DR' },
  { id: 'problem', label: 'Problem' },
  { id: 'core-idea', label: 'Core idea' },
  { id: 'method-architecture', label: 'Method' },
  { id: 'results-evidence', label: 'Results' },
  { id: 'visuals-figures', label: 'Visuals' },
  { id: 'related-summary', label: 'Related summary' },
  { id: 'technical-notes', label: 'Technical notes' }
];

export async function getStaticPaths() {
  const projects = (await getCollection('projects'))
    .filter((project) => project.data.status === 'Research')
    .filter(
      (project) =>
        !['hamjepa', 'chebyshev-option-surfaces'].includes(entrySlug(project.id))
    )
    .sort(sortByOrder);

  return projects.map((project) => ({
    params: { slug: entrySlug(project.id) },
    props: { project }
  }));
}

const { project } = Astro.props as Props;
const slug = entrySlug(project.id);
const details = PROJECT_DETAILS[slug] ?? PROJECT_DETAILS.hamjepa;
const { Content } = await render(project);

const summaries = (await getCollection('summaries')).sort(sortByOrder);
const relatedSummary = summaries.find((summary) => summary.data.projectSlug === slug);

const explicitProjectLinks = new Map(
  project.data.externalLinks.map((link) => [link.label.toLowerCase(), link.href])
);

function firstLinkByKeywords(keywords: string[]): string | undefined {
  for (const [label, href] of explicitProjectLinks) {
    if (keywords.some((keyword) => label.includes(keyword))) {
      return href;
    }
  }

  return undefined;
}

const paperLink =
  firstLinkByKeywords(['paper']) ??
  (slug === 'hamjepa'
    ? withBase(siteConfig.links.hamjepaPaper)
    : slug === 'chebyshev-option-surfaces'
      ? siteConfig.links.chebyshevPaper
      : undefined);

const codeLink =
  firstLinkByKeywords(['code']) ?? (slug === 'hamjepa' ? siteConfig.links.hamjepaCode : undefined);

const arxivLink =
  firstLinkByKeywords(['arxiv']) ??
  (paperLink?.includes('arxiv.org') ? paperLink : siteConfig.links.arxivAuthor);

const linkBadges: LinkBadge[] = [
  { label: 'Paper', href: paperLink },
  { label: 'Code', href: codeLink },
  { label: 'Zenodo', href: siteConfig.links.zenodo },
  { label: 'GitHub', href: siteConfig.links.github },
  { label: 'arXiv Author', href: arxivLink },
  { label: 'Technical summary', href: relatedSummary ? summaryHref(relatedSummary) : undefined }
];

function visualCaption(assetLabel: string): string {
  const lower = assetLabel.toLowerCase();

  if (lower.includes('qp') || lower.includes('q p') || lower.includes('decomposition')) {
    return 'q/p decomposition diagnostics.';
  }

  if (lower.includes('epoch')) {
    return 'Epoch dynamics and training-trajectory behavior.';
  }

  if (lower.includes('symplectic') || lower.includes('reversibility') || lower.includes('energy')) {
    return 'Structure-preservation diagnostics (symplecticity, reversibility, energy).';
  }

  if (lower.includes('fog') || lower.includes('surface') || lower.includes('projection')) {
    return 'Surface geometry and local post-fit behavior.';
  }

  return 'Diagnostic figure frame aligned with the current research section.';
}

function visualTag(assetName: string): string {
  const lower = assetName.toLowerCase();

  if (lower.endsWith('.gif')) {
    return 'Animated diagnostic';
  }

  if (lower.includes('energy') || lower.includes('symplectic') || lower.includes('reversibility')) {
    return 'Structure check';
  }

  if (lower.includes('surface') || lower.includes('projection') || lower.includes('fog')) {
    return 'Surface geometry';
  }

  return 'Figure';
}

const imagesDir = fileURLToPath(new URL('../../../public/images/hamjepa', import.meta.url));
const mediaExtensions = new Set(['.png', '.jpg', '.jpeg', '.webp', '.avif', '.gif', '.mp4', '.webm']);

const availableMedia = existsSync(imagesDir)
  ? readdirSync(imagesDir)
      .filter((name: string) => {
        const dotIndex = name.lastIndexOf('.');
        if (dotIndex <= 0) return false;
        return mediaExtensions.has(name.slice(dotIndex).toLowerCase());
      })
      .map((name: string) => ({
        name,
        src: withBase(`/images/hamjepa/${name}`),
        label: readableAssetLabel(name),
        lower: name.toLowerCase()
      }))
  : [];

const visualKeywords: Record<string, string[]> = {
  hamjepa: [
    'hamjepa',
    'jepa',
    'qp',
    'decomposition',
    'epoch',
    'symplectic',
    'liouville',
    'reversibility',
    'energy',
    'covariance',
    'drift'
  ],
  'chebyshev-option-surfaces': [
    'chebyshev',
    'option',
    'surface',
    'projection',
    'fog',
    'arbitrage',
    'noarb',
    'no-arb'
  ]
};

const keywordMatches = availableMedia.filter((asset: (typeof availableMedia)[number]) =>
  (visualKeywords[slug] ?? []).some((keyword) => asset.lower.includes(keyword))
);

const explicitNames = project.data.assets
  .filter((asset) => /\.[a-z0-9]+$/i.test(asset))
  .map((asset) => asset.toLowerCase());

const explicitMatches = availableMedia.filter((asset: (typeof availableMedia)[number]) =>
  explicitNames.includes(asset.lower)
);

const mergedMedia = [...explicitMatches, ...keywordMatches].filter(
  (asset: (typeof availableMedia)[number], index: number, array: typeof availableMedia) =>
    array.findIndex((candidate) => candidate.name === asset.name) === index
);

const fallbackVisuals: Record<string, Array<{ title: string; caption: string; tag?: string }>> = {
  hamjepa: [
    {
      title: 'q/p decomposition',
      caption: 'Separate geometry in q and p coordinates to diagnose where representation gains are carried.',
      tag: 'Phase-space'
    },
    {
      title: 'Epoch dynamics',
      caption: 'Track learning trajectory shape across training and compare stability to isotropic baselines.',
      tag: 'Training dynamics'
    },
    {
      title: 'Symplecticity and reversibility',
      caption: 'Use structure checks to verify the predictor remains close to intended Hamiltonian behavior.',
      tag: 'Structure check'
    },
    {
      title: 'Energy drift behavior',
      caption: 'Inspect energy drift under rollout to monitor long-horizon degradation risk.',
      tag: 'Drift diagnostics'
    }
  ],
  'chebyshev-option-surfaces': [
    {
      title: 'Price-space surface view',
      caption: 'Fit the arbitrage-carrying forward-discounted call object directly in C_f(m, tau).',
      tag: 'Surface geometry'
    },
    {
      title: 'Constraint projection',
      caption: 'Linear inequality operators encode convexity, monotonicity, and calendar structure.',
      tag: 'No-arbitrage constraints'
    },
    {
      title: 'Hamiltonian fog patches',
      caption: 'Local post-fit repair is activated only where quotes are noisy or internally inconsistent.',
      tag: 'Post-fit layer'
    }
  ]
};

const visuals =
  mergedMedia.length > 0
    ? mergedMedia.map((asset) => ({
        title: asset.label,
        src: asset.src,
        caption: visualCaption(asset.label),
        tag: visualTag(asset.name)
      }))
    : fallbackVisuals[slug] ?? [];

function findMediaByKeywords(keywords: string[]): string | undefined {
  const match = mergedMedia.find((asset) => keywords.some((keyword) => asset.lower.includes(keyword)));
  return match?.src;
}

const hamjepaStoryItems =
  slug === 'hamjepa'
    ? [
        {
          id: 'qp-decomposition',
          title: 'Phase-space decomposition s = (q, p)',
          caption:
            'Separate q and p behavior to expose where representation geometry is gained rather than averaging everything into isotropic latent directions.',
          mediaSrc: findMediaByKeywords(['qp', 'decomposition']),
          tag: 'Representation geometry',
          metric: 'q linear: 31.92 vs 24.40'
        },
        {
          id: 'epoch-dynamics',
          title: 'Training trajectory dynamics',
          caption:
            'Epoch-level diagnostics highlight that geometric structure is carried by the predictive map, not by forcing isotropic marginals.',
          mediaSrc: findMediaByKeywords(['epoch', 'dynamics']),
          tag: 'Training behavior',
          metric: 'q kNN: 24.92 vs 20.10'
        },
        {
          id: 'symplecticity-reversibility',
          title: 'Symplecticity and reversibility checks',
          caption:
            'The predictor is monitored for structure-preserving behavior under rollout, treating reversibility and symplecticity defect as model-health signals.',
          mediaSrc: findMediaByKeywords(['symplectic', 'reversibility', 'liouville']),
          tag: 'Structure check'
        },
        {
          id: 'energy-drift',
          title: 'Energy drift diagnostics',
          caption:
            'Energy-aware diagnostics keep long-horizon behavior interpretable and reduce silent degradation relative to isotropy-centered predictors.',
          mediaSrc: findMediaByKeywords(['energy', 'drift']),
          tag: 'Drift diagnostics'
        }
      ]
    : [];

const metrics = RESULT_METRICS[slug] ?? project.data.headlineMetrics;
const description = `${project.data.title}. ${project.data.thesis}`;
const useUnifiedVisualShell = slug === 'chebyshev-option-surfaces';
const summaryPdfFallbackBySlug: Record<string, string> = {
  hamjepa: withBase('/files/summary_hamjepa.pdf'),
  'chebyshev-option-surfaces': withBase('/files/summaries/chebyshev-technical-summary.pdf')
};
const summaryPdfHref = relatedSummary?.data.pdfPath ?? summaryPdfFallbackBySlug[slug];
const visualShellTags = [
  { label: project.data.category },
  { label: 'Visual guide', tone: 'accent' as const }
];
const visualShellActions = [
  { label: 'Technical summary', href: relatedSummary ? summaryHref(relatedSummary) : undefined },
  {
    label: 'Paper PDF',
    href: paperLink,
    external: Boolean(paperLink),
    ariaLabel: 'Paper PDF',
    title: 'Paper PDF'
  },
  {
    label: 'Summary PDF',
    href: summaryPdfHref,
    external: Boolean(summaryPdfHref),
    ariaLabel: 'Summary PDF',
    title: 'Summary PDF'
  },
  {
    label: 'Zenodo',
    href: siteConfig.links.zenodo,
    external: true
  }
];

const routePath = `/research/${slug}`;
const canonicalUrl = toAbsoluteUrl(routePath);

const sameAsLinks = Array.from(
  new Set(
    [paperLink, codeLink, siteConfig.links.github, siteConfig.links.zenodo, siteConfig.links.arxivAuthor].filter(
      (href): href is string => Boolean(href && !isPlaceholderLink(href))
    )
  )
);

const researchJsonLd =
  project.data.status === 'Research'
    ? {
        '@context': 'https://schema.org',
        '@type': 'ScholarlyArticle',
        headline: project.data.title,
        abstract: project.data.thesis,
        description,
        url: canonicalUrl,
        author: {
          '@type': 'Person',
          name: siteConfig.name
        },
        about: [project.data.category, ...project.data.keyPoints.slice(0, 3)],
        isAccessibleForFree: true,
        genre: 'Research',
        sameAs: sameAsLinks,
        mainEntityOfPage: canonicalUrl
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'CreativeWork',
        name: project.data.title,
        description: project.data.thesis,
        url: canonicalUrl,
        creator: {
          '@type': 'Person',
          name: siteConfig.name
        },
        genre: 'Ongoing research direction'
      };
---

<BaseLayout
  title={`${project.data.title} | Research`}
  description={description}
  ogType="article"
  jsonLd={researchJsonLd}
>
  {
    useUnifiedVisualShell ? (
      <ResearchPageShell
        title={project.data.title}
        description={details.heroSupport}
        tags={visualShellTags}
        actions={visualShellActions}
        actionsAriaLabel={`${project.data.title} visual guide actions`}
        intro="This visual guide walks through the Chebyshev option-surface pipeline from price-space setup and warped tensor basis construction to sparse no-arbitrage operators and local Hamiltonian fog post-fit."
      />
    ) : (
      <>
        <section class="surface-dark section-space">
          <div class="page-shell space-y-7" data-reveal>
            <a href={withBase('/research')} class="subtle-link text-sm text-[color:var(--dark-muted)]">
              <span aria-hidden="true">←</span> Back to research index
            </a>

            <div class="flex flex-wrap gap-2">
              <Badge label={project.data.category} />
              <Badge label={project.data.status} tone="accent" />
            </div>

            <h1 class="display-title max-w-5xl">{project.data.title}</h1>
            <p class="lede">{details.heroSupport}</p>
            <div class="flex flex-wrap gap-2">
              {metrics.slice(0, 2).map((metric) => (
                <span class="metric-pill">{metric}</span>
              ))}
            </div>
          </div>
        </section>

        <section id="external-links" class="surface-light section-tight section-divider">
          <div class="page-shell space-y-4">
            <ExternalLinkPills links={linkBadges} ariaLabel={`${project.data.title} external links`} />
          </div>
        </section>
      </>
    )
  }

  <section class:list={['section-space', !useUnifiedVisualShell && 'section-divider']}>
    <div class="page-shell grid gap-8 lg:grid-cols-[220px_minmax(0,1fr)] lg:items-start">
      <aside class="hidden lg:block lg:sticky lg:top-28">
        <nav aria-label="Page sections" class="card space-y-2 p-4">
          <p class="meta-label mb-2">On this page</p>
          <ul class="toc-list text-sm">
            {SECTION_LINKS.map((section) => (
              <li>
                <a href={`#${section.id}`} class="toc-link">
                  {section.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <div class="space-y-6">
        <article id="tldr" class="card" data-reveal>
          <p class="meta-label mb-3">TL;DR / Thesis</p>
          <p class="body-copy mb-4">{details.tldr}</p>
          <ul class="bullet-list text-sm" aria-label="Key points">
            {project.data.keyPoints.slice(0, 4).map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>

        <article id="problem" class="card" data-reveal>
          <p class="meta-label mb-3">Problem</p>
          <p class="body-copy mb-3">{project.data.problem}</p>
          <p class="body-copy">{details.problemDeep}</p>
        </article>

        <article id="core-idea" class="card" data-reveal>
          <p class="meta-label mb-3">Core Idea</p>
          <p class="body-copy mb-3">{project.data.coreIdea}</p>
          <p class="body-copy">{details.coreIdeaDeep}</p>
        </article>

        <article id="method-architecture" class="card" data-reveal>
          <p class="meta-label mb-3">Method / Architecture</p>
          <p class="body-copy mb-4">{project.data.method}</p>
          <ul class="bullet-list text-sm">
            {details.methodBullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>

          {slug === 'chebyshev-option-surfaces' && (
            <div class="method-flow mt-6">
              <p class="meta-label mb-3">Method flow</p>
              <ol class="method-flow-list">
                <li>Forward-discounted call sheet C_f(m, tau)</li>
                <li>Warp coordinates near ATM and short maturity for approximation stability</li>
                <li>Expand in tensor Chebyshev basis and solve convex QP backbone</li>
                <li>Apply Hamiltonian fog locally only on inconsistent patches</li>
              </ol>
            </div>
          )}
        </article>

        <article id="results-evidence" class="surface-dark card border-white/20" data-reveal>
          <p class="meta-label mb-3">Results / Evidence</p>
          <p class="body-copy mb-4">{project.data.results}</p>
          <p class="body-copy mb-5">{details.resultsDeep}</p>

          <MetricStrip metrics={metrics} tone="dark" columns={slug === 'hamjepa' ? 3 : 2} />

          <div class="mt-5">
            <CalloutStat
              tone="dark"
              label={details.highlightResult.title}
              value={details.highlightResult.body}
            />
          </div>
        </article>

        {slug === 'hamjepa' && (
          <section class="space-y-4" data-reveal>
            <StickyFigureStory
              heading="Visual walkthrough"
              intro="A guided sequence through decomposition, training dynamics, and structure diagnostics."
              items={hamjepaStoryItems}
            />
          </section>
        )}

        <article id="visuals-figures" class="card" data-reveal>
          <p class="meta-label mb-3">Visuals / Figures</p>
          <p class="body-copy mb-5">{details.figureLead}</p>
          <FigureGrid
            figures={visuals}
            featuredFirst
          />
        </article>

        <article id="related-summary" class="surface-dark card border-white/20" data-reveal>
          <p class="meta-label mb-3">Related Summary</p>
          {relatedSummary ? (
            <div class="space-y-4">
              <h2 class="text-3xl">{relatedSummary.data.title}</h2>
              <p class="text-[color:var(--dark-muted)]">{relatedSummary.data.standfirst}</p>
              <div class="flex flex-wrap gap-3">
                <a href={summaryHref(relatedSummary)} class="site-nav-cta">
                  Technical summary
                </a>
                <a
                  href={withBase('/about')}
                  class="inline-flex items-center justify-center rounded-full border border-white/35 px-5 py-2 text-sm font-semibold text-white transition-colors hover:border-white/65"
                >
                  View About / CV
                </a>
              </div>
            </div>
          ) : (
            <div class="space-y-3">
              <p class="body-copy">
                A dedicated web-native summary is not published yet for this project.
              </p>
              <a href={withBase('/research')} class="subtle-link text-sm text-white">
                Browse research library <span aria-hidden="true">→</span>
              </a>
            </div>
          )}
        </article>

        <article id="technical-notes" class="card prose-panel" data-reveal>
          <p class="meta-label mb-2">Technical Notes / Next Steps</p>
          {project.data.warning && (
            <p class="mb-4 rounded-2xl border border-amber-500/40 bg-amber-500/12 px-4 py-3 text-amber-800">
              {project.data.warning}
            </p>
          )}

          <ul>
            {details.nextSteps.map((step) => (
              <li>{step}</li>
            ))}
          </ul>

          <Content />
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
