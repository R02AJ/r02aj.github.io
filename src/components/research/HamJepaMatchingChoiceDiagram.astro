<figure
  class="hamjepa-matching-figure"
  aria-labelledby="hamjepa-matching-title"
  aria-describedby="hamjepa-matching-caption"
>
  <div class="hamjepa-matching-scroll" tabindex="0" aria-label="Scrollable CIFAR and ImageNet matching-choice diagram">
    <svg
      class="hamjepa-matching-svg"
      viewBox="0 0 1220 480"
      role="img"
      aria-labelledby="hamjepa-matching-title hamjepa-matching-desc"
      preserveAspectRatio="xMidYMid meet"
    >
      <title id="hamjepa-matching-title">CIFAR-100 and ImageNet-100 matching-choice comparison</title>
      <desc id="hamjepa-matching-desc">
        Left panel CIFAR-100 emphasizes matching mainly q while p remains auxiliary. Right panel ImageNet-100 matches
        full [q;p], directly constraining both coordinates.
      </desc>

      <defs>
        <marker id="ham-match-blue" markerWidth="9" markerHeight="9" refX="7.4" refY="4.5" orient="auto">
          <path d="M0,0 L9,4.5 L0,9 z" fill="#2f6f9d" />
        </marker>
        <marker id="ham-match-orange" markerWidth="9" markerHeight="9" refX="7.4" refY="4.5" orient="auto">
          <path d="M0,0 L9,4.5 L0,9 z" fill="#b67a2e" />
        </marker>
        <marker id="ham-match-soft" markerWidth="9" markerHeight="9" refX="7.4" refY="4.5" orient="auto">
          <path d="M0,0 L9,4.5 L0,9 z" fill="#7f8d99" />
        </marker>
      </defs>

      <rect x="36" y="66" width="560" height="360" rx="14" class="panel" />
      <text x="316" y="44" class="t-head" text-anchor="middle">CIFAR-100</text>

      <rect x="90" y="142" width="126" height="66" rx="8" class="state-q-strong" />
      <rect x="90" y="214" width="126" height="66" rx="8" class="state-p-weak" />
      <text x="153" y="184" class="t-state" text-anchor="middle">q̂<tspan baseline-shift="sub" font-size="70%">b</tspan></text>
      <text x="153" y="254" class="t-state" text-anchor="middle">p̂<tspan baseline-shift="sub" font-size="70%">b</tspan></text>

      <rect x="416" y="142" width="126" height="66" rx="8" class="state-q-strong" />
      <rect x="416" y="214" width="126" height="66" rx="8" class="state-p-weak" />
      <text x="479" y="184" class="t-state" text-anchor="middle">q<tspan baseline-shift="sub" font-size="70%">b</tspan></text>
      <text x="479" y="254" class="t-state" text-anchor="middle">p<tspan baseline-shift="sub" font-size="70%">b</tspan></text>

      <rect x="246" y="284" width="140" height="78" rx="10" class="match-box" />
      <text x="316" y="316" class="t-match" text-anchor="middle">match mainly</text>
      <text x="316" y="346" class="t-match-math" text-anchor="middle">q</text>
      <line x1="216" y1="176" x2="246" y2="304" class="a-blue" marker-end="url(#ham-match-blue)" />
      <line x1="416" y1="176" x2="386" y2="304" class="a-blue" marker-end="url(#ham-match-blue)" />
      <line x1="216" y1="248" x2="274" y2="248" class="a-soft" marker-end="url(#ham-match-soft)" />
      <line x1="416" y1="248" x2="356" y2="248" class="a-soft" marker-end="url(#ham-match-soft)" />
      <text x="316" y="396" class="t-note" text-anchor="middle">q is the main content coordinate; p is more auxiliary</text>

      <rect x="624" y="66" width="560" height="360" rx="14" class="panel" />
      <text x="904" y="44" class="t-head" text-anchor="middle">ImageNet-100</text>

      <rect x="678" y="142" width="126" height="66" rx="8" class="state-q-strong" />
      <rect x="678" y="214" width="126" height="66" rx="8" class="state-p-strong" />
      <text x="741" y="184" class="t-state" text-anchor="middle">q̂<tspan baseline-shift="sub" font-size="70%">b</tspan></text>
      <text x="741" y="254" class="t-state" text-anchor="middle">p̂<tspan baseline-shift="sub" font-size="70%">b</tspan></text>

      <rect x="1004" y="142" width="126" height="66" rx="8" class="state-q-strong" />
      <rect x="1004" y="214" width="126" height="66" rx="8" class="state-p-strong" />
      <text x="1067" y="184" class="t-state" text-anchor="middle">q<tspan baseline-shift="sub" font-size="70%">b</tspan></text>
      <text x="1067" y="254" class="t-state" text-anchor="middle">p<tspan baseline-shift="sub" font-size="70%">b</tspan></text>

      <rect x="834" y="284" width="140" height="78" rx="10" class="match-box" />
      <text x="904" y="316" class="t-match" text-anchor="middle">match full</text>
      <text x="904" y="346" class="t-match-math" text-anchor="middle">[q; p]</text>

      <line x1="804" y1="176" x2="834" y2="304" class="a-blue" marker-end="url(#ham-match-blue)" />
      <line x1="1004" y1="176" x2="974" y2="304" class="a-blue" marker-end="url(#ham-match-blue)" />
      <line x1="804" y1="248" x2="834" y2="336" class="a-orange" marker-end="url(#ham-match-orange)" />
      <line x1="1004" y1="248" x2="974" y2="336" class="a-orange" marker-end="url(#ham-match-orange)" />

      <text x="904" y="396" class="t-note" text-anchor="middle">both coordinates are directly constrained</text>
    </svg>
  </div>

  <figcaption id="hamjepa-matching-caption" class="hamjepa-matching-caption">
    <strong>Why CIFAR-100 and ImageNet-100 use different matching choices.</strong> On CIFAR-100 the training
    objective emphasizes the content coordinate q, so q is the cleanest downstream readout and p mainly supports the
    dynamics. On ImageNet-100 the stable regime was to match the full state [q;p], which directly constrains both
    coordinates and makes p much more informative.
  </figcaption>
</figure>

