---
import { existsSync, readdirSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { withBase } from '../../data/site';

type Props = {
  stem: string;
  alt: string;
};

const { stem, alt } = Astro.props;

const imagesDir = fileURLToPath(new URL('../../../public/images/chebyshev', import.meta.url));
const files = existsSync(imagesDir) ? readdirSync(imagesDir) : [];
const lower = new Map(files.map((name) => [name.toLowerCase(), name]));

function find(name: string): string | undefined {
  return lower.get(name.toLowerCase());
}

function resolve(stemValue: string): string {
  const orbitStems = new Set(['00_hero_price_sheet_orbit', '16_fog_lattice_orbit']);
  const extensions = orbitStems.has(stemValue)
    ? ['.mp4', '.webm', '.gif', '.png', '.jpg', '.jpeg', '.webp', '.svg', '.pdf']
    : ['.png', '.jpg', '.jpeg', '.webp', '.svg', '.pdf', '.gif', '.mp4', '.webm'];

  for (const ext of extensions) {
    const hit = find(`${stemValue}${ext}`);
    if (hit) {
      return withBase(`/images/chebyshev/${hit}`);
    }
  }

  throw new Error(`Missing required Chebyshev visual-guide asset stem: ${stemValue} in public/images/chebyshev`);
}

const src = resolve(stem);
const isVideo = src.endsWith('.mp4') || src.endsWith('.webm');
const hasCaption = Astro.slots.has('default');
---

<figure class="ham-geo-figure lift">
  <div class="ham-geo-media-shell">
    {
      isVideo ? (
        <video class="ham-geo-media" autoplay muted loop playsinline preload="metadata">
          <source src={src} type={src.endsWith('.webm') ? 'video/webm' : 'video/mp4'} />
        </video>
      ) : (
        <img src={src} alt={alt} loading="lazy" decoding="async" class="ham-geo-media" />
      )
    }
  </div>
  {
    hasCaption && (
      <figcaption class="ham-geo-figure-copy">
        <slot />
      </figcaption>
    )
  }
</figure>
